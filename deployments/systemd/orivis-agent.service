[Unit]
Description=Orivis Agent
After=network-online.target orivis-server.service
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/orivis/agent.env
ExecStart=/usr/local/bin/orivis-agent
Restart=on-failure
RestartSec=5s
User=orivis
Group=orivis
WorkingDirectory=/var/lib/orivis
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
