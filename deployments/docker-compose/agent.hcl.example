server {
  url = "http://server:8080"
}

agent {
  name = "compose-agent"
  token = "change-me"
  region = "local"
  environments = ["dev"]
}

poll {
  interval = "30s"
}

log {
  level = "info"
}

discovery {
  provider = "docker"

  static {
    enabled = true
  }

  probe "http" "server-health" {
    source_key = "static:server-health"
    target = "http://server:8080/healthz"
    group = "default"
    environment = "dev"
    enabled = true
    interval = "30s"
    timeout = "3s"
    retry_count = 0
    aggregation = "majority_down"
  }
}
