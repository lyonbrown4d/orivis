server {
  url = "http://server:8080"
}

agent {
  name = "compose-agent"
  token = "change-me"
  region = "local"
  environments = ["dev"]
}

poll {
  interval = "30s"
}

transport {
  request_timeout = "10s"
  max_idle_conns = 100
  max_idle_conns_per_host = 16
  idle_conn_timeout = "90s"
  tls_handshake_timeout = "10s"
  response_header_timeout = "10s"
  retry_attempts = 3
  retry_base_delay = "1s"
  retry_max_delay = "5s"
  retry_jitter_ratio = 0.2
  gzip_results = true
}

log {
  level = "info"
}

discovery {
  provider = "docker"

  static {
    enabled = true
  }

  probe "http" "server-health" {
    source_key = "static:server-health"
    target = "http://server:8080/healthz"
    group = "default"
    environment = "dev"
    enabled = true
    interval = "30s"
    timeout = "3s"
    retry_count = 0
    aggregation = "majority_down"
  }
}
