ORIVIS_SERVER__URL=http://server:8080
ORIVIS_AGENT__NAME=compose-agent
ORIVIS_AGENT__TOKEN=change-me
ORIVIS_AGENT__REGION=local
ORIVIS_AGENT__ENVIRONMENTS=dev
ORIVIS_POLL__INTERVAL=30s
ORIVIS_LOG__LEVEL=info

ORIVIS_BUFFER__ENABLED=true
ORIVIS_BUFFER__DRIVER=file
ORIVIS_BUFFER__PATH=/data/results.jsonl
ORIVIS_BUFFER__CAPACITY=4096

ORIVIS_TRANSPORT__REQUESTTIMEOUT=10s
ORIVIS_TRANSPORT__MAXIDLECONNS=100
ORIVIS_TRANSPORT__MAXIDLECONNSPERHOST=16
ORIVIS_TRANSPORT__IDLECONNTIMEOUT=90s
ORIVIS_TRANSPORT__TLSHANDSHAKETIMEOUT=10s
ORIVIS_TRANSPORT__RESPONSEHEADERTIMEOUT=10s
ORIVIS_TRANSPORT__RETRYATTEMPTS=3
ORIVIS_TRANSPORT__RETRYBASEDELAY=1s
ORIVIS_TRANSPORT__RETRYMAXDELAY=5s
ORIVIS_TRANSPORT__RETRYJITTERRATIO=0.2
ORIVIS_TRANSPORT__GZIPRESULTS=true

ORIVIS_DISCOVERY__STATIC__ENABLED=true
ORIVIS_DISCOVERY__STATIC__HCL_FILES=
ORIVIS_DISCOVERY__STATIC__MONITOR__SOURCE_KEY=static:server-health
ORIVIS_DISCOVERY__STATIC__MONITOR__NAME=server-health
ORIVIS_DISCOVERY__STATIC__MONITOR__TYPE=http
ORIVIS_DISCOVERY__STATIC__MONITOR__TARGET=http://server:8080/healthz
ORIVIS_DISCOVERY__STATIC__MONITOR__ENVIRONMENT=dev
ORIVIS_DISCOVERY__STATIC__MONITOR__ENABLED=true
ORIVIS_DISCOVERY__STATIC__MONITOR__INTERVAL=30s
ORIVIS_DISCOVERY__STATIC__MONITOR__TIMEOUT=3s
ORIVIS_DISCOVERY__STATIC__MONITOR__RETRY_COUNT=0
ORIVIS_DISCOVERY__STATIC__MONITOR__AGGREGATION=majority_down

ORIVIS_DISCOVERY__PROVIDER=docker
