ORIVIS_NOTIFICATION__WEBHOOK__ENABLED=true
ORIVIS_NOTIFICATION__WEBHOOK__METHOD=POST
ORIVIS_NOTIFICATION__WEBHOOK__TIMEOUT=5s
ORIVIS_NOTIFICATION__WEBHOOK__COOLDOWN=5m
ORIVIS_NOTIFICATION__WEBHOOK__QUEUESIZE=256
ORIVIS_NOTIFICATION__WEBHOOK__MAXATTEMPTS=5
ORIVIS_NOTIFICATION__WEBHOOK__RETRYINTERVAL=8s

# Optional default sink for unscoped routes.
ORIVIS_NOTIFICATION__WEBHOOK__URL=https://hooks.example.internal/uptime
ORIVIS_NOTIFICATION__WEBHOOK__SECRET=
ORIVIS_NOTIFICATION__WEBHOOK__HEADERS=X-Source=orivis

# Webhook route for ops channels only.
ORIVIS_NOTIFICATION__WEBHOOK__ROUTES=name=ops-webhook;type=webhook;groups=ops;url=https://hooks.example.internal/ops;secret=change-me

# Alertmanager route for critical monitors.
ORIVIS_NOTIFICATION__WEBHOOK__ROUTES=name=alertmanager;type=alertmanager;groups=critical|prod;url=http://alertmanager:9093/api/v2/alerts

ORIVIS_NOTIFICATION__WEBHOOK__RECOVERYENABLED=true
