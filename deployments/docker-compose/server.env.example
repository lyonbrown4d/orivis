ORIVIS_APP__ENV=production
ORIVIS_HTTP__ADDR=:8080
ORIVIS_HTTP__BODYLIMITBYTES=4194304
ORIVIS_LOG__LEVEL=info

ORIVIS_DB__DRIVER=sqlite
ORIVIS_DB__DSN=file:/data/orivis.db?cache=shared

# Production database example (PostgreSQL via pgx):
# ORIVIS_DB__DRIVER=pgx
# ORIVIS_DB__DSN=postgres://orivis:orivis@postgres:5432/orivis?sslmode=disable
# ORIVIS_DB__MAXOPENCONNS=16

# Production database example (MySQL):
# ORIVIS_DB__DRIVER=mysql
# ORIVIS_DB__DSN=mysql://orivis:orivis@mysql:3306/orivis?parseTime=true
# ORIVIS_DB__MAXOPENCONNS=16
ORIVIS_DB__MAXOPENCONNS=4
ORIVIS_DB__BUSYTIMEOUT=5s

ORIVIS_CACHE__DRIVER=memory
ORIVIS_CACHE__PREFIX=orivis
ORIVIS_CACHE__REDIS__ADDR=redis:6379
ORIVIS_CACHE__REDIS__PASSWORD=
ORIVIS_CACHE__REDIS__DB=0
ORIVIS_CACHE__REDIS__TLS=false

ORIVIS_DASHBOARD__SNAPSHOTTTL=1s

ORIVIS_INGEST__QUEUESIZE=4096
ORIVIS_INGEST__BATCHSIZE=100
ORIVIS_INGEST__FLUSHINTERVAL=1s

ORIVIS_RETENTION__ENABLED=true
ORIVIS_RETENTION__RESULTTTL=168h
ORIVIS_RETENTION__CLEANUPINTERVAL=1h

ORIVIS_AUTH__AGENT__TOKEN=change-me
ORIVIS_AUTH__DASHBOARD__ENABLED=true
ORIVIS_AUTH__DASHBOARD__USERNAME=admin
ORIVIS_AUTH__DASHBOARD__PASSWORD=change-me
ORIVIS_AUTH__DASHBOARD__JWT_SECRET=change-me-random-32-bytes-minimum
ORIVIS_AUTH__DASHBOARD__SECURE_COOKIE=false

ORIVIS_OBSERVABILITY__PROMETHEUS__ENABLED=false
ORIVIS_OBSERVABILITY__PROMETHEUS__NAMESPACE=orivis

ORIVIS_NOTIFICATION__WEBHOOK__ENABLED=false
ORIVIS_NOTIFICATION__WEBHOOK__URL=
ORIVIS_NOTIFICATION__WEBHOOK__METHOD=POST
ORIVIS_NOTIFICATION__WEBHOOK__TIMEOUT=5s
ORIVIS_NOTIFICATION__WEBHOOK__COOLDOWN=5m
ORIVIS_NOTIFICATION__WEBHOOK__QUEUESIZE=128
ORIVIS_NOTIFICATION__WEBHOOK__MAXATTEMPTS=3
ORIVIS_NOTIFICATION__WEBHOOK__RETRYINTERVAL=5s
ORIVIS_NOTIFICATION__WEBHOOK__SECRET=
ORIVIS_NOTIFICATION__WEBHOOK__HEADERS=
ORIVIS_NOTIFICATION__WEBHOOK__ROUTES=
ORIVIS_NOTIFICATION__WEBHOOK__RECOVERYENABLED=true
