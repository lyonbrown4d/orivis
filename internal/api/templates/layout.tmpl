<!doctype html>
<html lang="{{.Lang}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="refresh" content="15">
  <title>{{call .T "page.title"}} | Orivis</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/uplot@1.6.32/dist/uPlot.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/uplot@1.6.32/dist/uPlot.iife.min.js"></script>
</head>
<body class="min-h-screen bg-[#f5f1e8] text-slate-950">
  <div class="mx-auto flex min-h-screen max-w-7xl gap-4 px-4 py-5 lg:px-8">
    <aside class="w-full max-w-[260px] rounded-[1.6rem] border border-slate-900/10 bg-white p-4 shadow-sm lg:block">
      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-slate-500">{{call .T "page.subtitle"}}</p>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-900">{{call .T "page.title"}}</h1>
        <p class="mt-3 text-sm text-slate-500">{{call .T "status.description"}}</p>
      </div>

      <div class="mt-8 space-y-1 text-sm">
        <a class="block rounded-xl border border-slate-200 bg-slate-50 px-4 py-2" href="/?lang={{.Lang}}#overview">{{call .T "nav.dashboard"}}</a>
        <a class="block rounded-xl border border-transparent px-4 py-2 hover:border-slate-200 hover:bg-white" href="/?lang={{.Lang}}#timeline">{{call .T "nav.timeline"}}</a>
        <a class="block rounded-xl border border-transparent px-4 py-2 hover:border-slate-200 hover:bg-white" href="/?lang={{.Lang}}#monitors">{{call .T "nav.monitors"}}</a>
        <a class="block rounded-xl border border-transparent px-4 py-2 hover:border-slate-200 hover:bg-white" href="/?lang={{.Lang}}#agents">{{call .T "nav.agents"}}</a>
        <a class="block rounded-xl border border-transparent px-4 py-2 hover:border-slate-200 hover:bg-white" href="/?lang={{.Lang}}#results">{{call .T "nav.results"}}</a>
      </div>

      <div class="mt-8 border-t border-slate-200 pt-4">
        <p class="text-xs uppercase tracking-[0.22em] text-slate-500">{{call .T "lang.current"}}</p>
        <div class="mt-3 flex gap-2">
          {{range .LangOptions}}
          <button
            type="button"
            class="rounded-full px-3 py-1 text-xs {{if .Active}}bg-slate-900 text-white{{else}}border border-slate-300 bg-white text-slate-700{{end}}"
            onclick="switchLang('{{.Code}}')"
          >{{.Label}}</button>
          {{end}}
        </div>
      </div>
    </aside>

    <main class="min-w-0 flex-1">
      {{embed}}
    </main>
  </div>

  <script>
    (function() {
      const preferred = localStorage.getItem('orivis_lang');
      const params = new URLSearchParams(window.location.search);
      if (!params.get('lang') && preferred) {
        params.set('lang', preferred);
        const hash = window.location.hash || '#overview';
        const next = `${window.location.pathname}?${params.toString()}${hash}`;
        window.location.replace(next);
      }
    })();

    function switchLang(code) {
      localStorage.setItem('orivis_lang', code);
      const params = new URLSearchParams(window.location.search);
      params.set('lang', code);
      const hash = window.location.hash || '#overview';
      const next = `${window.location.pathname}?${params.toString()}${hash}`;
      window.location.replace(next);
    }
  </script>
</body>
</html>
