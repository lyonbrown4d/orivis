# Orivis dotenv example.
#
# configx loads .env and .env.local automatically.
# Use "__" for nested config keys. Single underscores are preserved in field names.

# ---------------------------------------------------------------------------
# Shared
# ---------------------------------------------------------------------------
ORIVIS_LOG__LEVEL=info

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
ORIVIS_APP__ENV=development
ORIVIS_HTTP__ADDR=:8080
ORIVIS_WEB__ENABLED=false
ORIVIS_WEB__ROOT=web/dist

# Storage: sqlite. The default DSN is an in-memory sqlite database.
ORIVIS_DB__DRIVER=sqlite
ORIVIS_DB__DSN=file:orivis?mode=memory&cache=shared
ORIVIS_DB__MAXOPENCONNS=4
ORIVIS_DB__BUSYTIMEOUT=5s

# Cache: memory by default. Redis can be enabled for external shared cache.
ORIVIS_CACHE__DRIVER=memory
ORIVIS_CACHE__PREFIX=orivis
ORIVIS_CACHE__REDIS__ADDR=127.0.0.1:6379
ORIVIS_CACHE__REDIS__PASSWORD=
ORIVIS_CACHE__REDIS__DB=0
ORIVIS_CACHE__REDIS__TLS=false

# Dashboard API cache for local single-node UI polling.
ORIVIS_DASHBOARD__SNAPSHOTTTL=1s

# Server-side async result ingestion.
ORIVIS_INGEST__QUEUESIZE=4096
ORIVIS_INGEST__BATCHSIZE=100
ORIVIS_INGEST__FLUSHINTERVAL=1s

# Probe result retention. The default keeps seven days of results.
ORIVIS_RETENTION__ENABLED=true
ORIVIS_RETENTION__RESULTTTL=168h
ORIVIS_RETENTION__CLEANUPINTERVAL=1h

# Optional bootstrap token for agent registration.
# When set on the server, the agent must use the same ORIVIS_AGENT__TOKEN.
ORIVIS_AUTH__AGENT__TOKEN=

# Optional dashboard login.
ORIVIS_AUTH__DASHBOARD__ENABLED=false
ORIVIS_AUTH__DASHBOARD__USERNAME=admin
ORIVIS_AUTH__DASHBOARD__PASSWORD=
ORIVIS_AUTH__DASHBOARD__SECURE_COOKIE=false

# Observability.
ORIVIS_OBSERVABILITY__PROMETHEUS__ENABLED=false
ORIVIS_OBSERVABILITY__PROMETHEUS__NAMESPACE=orivis

# Optional webhook notifications. Alerts are sent on non-up status transitions;
# recovery events are sent when the monitor returns to up.
ORIVIS_NOTIFICATION__WEBHOOK__ENABLED=false
ORIVIS_NOTIFICATION__WEBHOOK__URL=
ORIVIS_NOTIFICATION__WEBHOOK__METHOD=POST
ORIVIS_NOTIFICATION__WEBHOOK__TIMEOUT=5s
ORIVIS_NOTIFICATION__WEBHOOK__COOLDOWN=5m
ORIVIS_NOTIFICATION__WEBHOOK__QUEUESIZE=128
ORIVIS_NOTIFICATION__WEBHOOK__MAXATTEMPTS=3
ORIVIS_NOTIFICATION__WEBHOOK__RETRYINTERVAL=5s
ORIVIS_NOTIFICATION__WEBHOOK__SECRET=
ORIVIS_NOTIFICATION__WEBHOOK__HEADERS=
ORIVIS_NOTIFICATION__WEBHOOK__RECOVERYENABLED=true

# ---------------------------------------------------------------------------
# Agent
# ---------------------------------------------------------------------------
ORIVIS_SERVER__URL=http://127.0.0.1:8080
ORIVIS_AGENT__NAME=local-agent
ORIVIS_AGENT__TOKEN=
ORIVIS_AGENT__REGION=local
ORIVIS_AGENT__ENVIRONMENTS=dev
ORIVIS_RUNTIME=host
ORIVIS_POLL__INTERVAL=30s
ORIVIS_POLL__JITTER=5s

# Agent-side bounded memory buffer for failed result reports.
# When the server is temporarily unavailable, failed probe results are retried
# from this FIFO buffer. When full, the oldest buffered result is dropped.
ORIVIS_BUFFER__ENABLED=true
ORIVIS_BUFFER__CAPACITY=1024

# Static discovery.
# The MONITOR block is a single-monitor dotenv shortcut for local testing.
# Use config.example.yaml or config.example.hcl when multiple static monitors are needed.
# Supported probe types: http, tcp, udp, smtp, memcached, ping, redis, mongodb, mongo, amqp, rabbitmq, nats, kafka, database, sqlite, mysql, postgres, pg, dns, tls.
# Redis target example: redis://127.0.0.1:6379
# MongoDB target example: mongodb://127.0.0.1:27017
# RabbitMQ/AMQP target example: amqp://guest:guest@127.0.0.1:5672/
# NATS target example: nats://127.0.0.1:4222
# Kafka target example: kafka://127.0.0.1:9092?topic=orivis
# SQLite target example: sqlite://file:orivis?mode=memory&cache=shared
# MySQL target example: mysql://root:password@127.0.0.1:3306/app?parseTime=true
# PostgreSQL target example: postgres://postgres:password@127.0.0.1:5432/app?sslmode=disable
# Ping target example: 127.0.0.1
# UDP target example: udp://127.0.0.1:9000?payload=ping&expect=pong
# SMTP target example: smtp://127.0.0.1:25
# Memcached target example: memcached://127.0.0.1:11211
# TLS target example: tls://example.com:443?degraded_before=336h
ORIVIS_DISCOVERY__STATIC__ENABLED=true
ORIVIS_DISCOVERY__STATIC__HCL_FILES=
ORIVIS_DISCOVERY__STATIC__MONITOR__SOURCE_KEY=static:server-health
ORIVIS_DISCOVERY__STATIC__MONITOR__NAME=server-health
ORIVIS_DISCOVERY__STATIC__MONITOR__TYPE=http
ORIVIS_DISCOVERY__STATIC__MONITOR__TARGET=http://127.0.0.1:8080/healthz
ORIVIS_DISCOVERY__STATIC__MONITOR__GROUP=core
ORIVIS_DISCOVERY__STATIC__MONITOR__ENVIRONMENT=dev
ORIVIS_DISCOVERY__STATIC__MONITOR__ENABLED=true
ORIVIS_DISCOVERY__STATIC__MONITOR__INTERVAL=15s
ORIVIS_DISCOVERY__STATIC__MONITOR__TIMEOUT=3s
ORIVIS_DISCOVERY__STATIC__MONITOR__RETRY_COUNT=0
ORIVIS_DISCOVERY__STATIC__MONITOR__AGGREGATION=majority_down

# Docker discovery.
# When enabled, Docker labels can be minimal:
#   orivis.enable=true
#   orivis.group=datastores
#   orivis.monitor.type=redis
# The agent infers name, environment, host, and ports from container metadata.
ORIVIS_DISCOVERY__DOCKER__ENABLED=false
ORIVIS_DISCOVERY__DOCKER__MODE=container

