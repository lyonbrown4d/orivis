ORIVIS_APP_ENV=development
ORIVIS_HTTP_ADDR=:8080
ORIVIS_LOG_LEVEL=info
ORIVIS_DB_DRIVER=memory
ORIVIS_DB_DSN=
ORIVIS_DB_MEMORY_RESULT_RETENTION=24h
ORIVIS_DB_MEMORY_CLEANUP_INTERVAL=1m
ORIVIS_AUTH_AGENT_TOKEN=
ORIVIS_OBSERVABILITY_PROMETHEUS_ENABLED=false
ORIVIS_OBSERVABILITY_PROMETHEUS_NAMESPACE=orivis

ORIVIS_SERVER_URL=http://127.0.0.1:8080
ORIVIS_AGENT_NAME=local-agent
ORIVIS_AGENT_TOKEN=
ORIVIS_AGENT_REGION=local
ORIVIS_AGENT_ENVIRONMENTS=dev
ORIVIS_RUNTIME=host
ORIVIS_POLL_INTERVAL=30s
ORIVIS_DISCOVERY_DOCKER_ENABLED=false
ORIVIS_DISCOVERY_DOCKER_MODE=container
