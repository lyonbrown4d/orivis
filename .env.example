# Orivis dotenv example.
#
# configx loads .env and .env.local automatically.
# Use "__" for nested config keys. Single underscores are preserved in field names.

# ---------------------------------------------------------------------------
# Shared
# ---------------------------------------------------------------------------
ORIVIS_LOG__LEVEL=info

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
ORIVIS_APP__ENV=development
ORIVIS_HTTP__ADDR=:8080

# Storage: memory or sqlite.
ORIVIS_DB__DRIVER=memory
ORIVIS_DB__DSN=
ORIVIS_DB__RESULTRETENTION=24h
ORIVIS_DB__CLEANUPINTERVAL=1m

# Optional bootstrap token for agent registration.
# When set on the server, the agent must use the same ORIVIS_AGENT__TOKEN.
ORIVIS_AUTH__AGENT__TOKEN=

# Optional dashboard Basic Auth.
ORIVIS_AUTH__DASHBOARD__ENABLED=false
ORIVIS_AUTH__DASHBOARD__USERNAME=admin
ORIVIS_AUTH__DASHBOARD__PASSWORD=

# Observability.
ORIVIS_OBSERVABILITY__PROMETHEUS__ENABLED=false
ORIVIS_OBSERVABILITY__PROMETHEUS__NAMESPACE=orivis

# ---------------------------------------------------------------------------
# Agent
# ---------------------------------------------------------------------------
ORIVIS_SERVER__URL=http://127.0.0.1:8080
ORIVIS_AGENT__NAME=local-agent
ORIVIS_AGENT__TOKEN=
ORIVIS_AGENT__REGION=local
ORIVIS_AGENT__ENVIRONMENTS=dev
ORIVIS_RUNTIME=host
ORIVIS_POLL__INTERVAL=30s

# Static discovery.
# The MONITOR block is a single-monitor dotenv shortcut for local testing.
# Use config.example.yaml when multiple static monitors are needed.
ORIVIS_DISCOVERY__STATIC__ENABLED=true
ORIVIS_DISCOVERY__STATIC__MONITOR__SOURCE_KEY=static:server-health
ORIVIS_DISCOVERY__STATIC__MONITOR__NAME=server-health
ORIVIS_DISCOVERY__STATIC__MONITOR__TYPE=http
ORIVIS_DISCOVERY__STATIC__MONITOR__TARGET=http://127.0.0.1:8080/healthz
ORIVIS_DISCOVERY__STATIC__MONITOR__ENVIRONMENT=dev
ORIVIS_DISCOVERY__STATIC__MONITOR__ENABLED=true
ORIVIS_DISCOVERY__STATIC__MONITOR__INTERVAL=15s
ORIVIS_DISCOVERY__STATIC__MONITOR__TIMEOUT=3s
ORIVIS_DISCOVERY__STATIC__MONITOR__RETRY_COUNT=0
ORIVIS_DISCOVERY__STATIC__MONITOR__AGGREGATION=majority_down

# Docker discovery.
ORIVIS_DISCOVERY__DOCKER__ENABLED=false
ORIVIS_DISCOVERY__DOCKER__MODE=container

